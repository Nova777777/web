{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [
      {
        "source": "/api/:path*",
        "destination": "https://cloudtools-api.493024082.workers.dev/api/:path*",
        "regex": "^/api(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:/)?$"
      }
    ],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/blog/edit/[id]",
      "regex": "^/blog/edit/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/blog/edit/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/blog/[id]",
      "regex": "^/blog/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/blog/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/notebook/edit/[id]",
      "regex": "^/notebook/edit/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/notebook/edit/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/notebook/[id]",
      "regex": "^/notebook/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/notebook/(?<nxtPid>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/blog",
      "regex": "^/blog(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/blog(?:/)?$"
    },
    {
      "page": "/blog/new",
      "regex": "^/blog/new(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/blog/new(?:/)?$"
    },
    {
      "page": "/horoscope",
      "regex": "^/horoscope(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/horoscope(?:/)?$"
    },
    {
      "page": "/mbti",
      "regex": "^/mbti(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/mbti(?:/)?$"
    },
    {
      "page": "/notebook",
      "regex": "^/notebook(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/notebook(?:/)?$"
    },
    {
      "page": "/notebook/new",
      "regex": "^/notebook/new(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/notebook/new(?:/)?$"
    },
    {
      "page": "/tools",
      "regex": "^/tools(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/tools(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "RSC",
    "varyHeader": "RSC, Next-Router-State-Tree, Next-Router-Prefetch, Next-Router-Segment-Prefetch",
    "prefetchHeader": "Next-Router-Prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "Next-Router-Segment-Prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}